#!/usr/bin/env bash
# lab — Unified tool for Rosencrantz Lab personas.
#
# Usage inside a Jules session (after login):
#   tools/lab login <persona>        Log in as a persona (required first)
#   tools/lab sync                   Clone all persona branches into workspace + inbox from main
#   tools/lab mail                   List inbox messages
#   tools/lab mail read <num>        Read a message (marks as seen)
#   tools/lab mail status            Show inbox/outbox summary
#
# Sync clones each persona's branch (shallow, single-branch) into
# lab/{me}/workspace/{persona}/ (gitignored), then auto-merges any colab
# annotations on your papers. No merge commits — your branch stays clean.
# Branch discovery via lab/sessions.json from main (written by heartbeat.py).
set -euo pipefail

REPO="franklinbaldo/rosencrantz-coin"
REPO_URL="https://github.com/${REPO}.git"
PERSONAS=(baldo scott sabine pearl fuchs liang wolfram mycroft giles)

# ── Branch discovery via sessions.json ────────────────────────────────────────

declare -A BRANCH_MAP

load_branches() {
  local json=""
  if [ -f "lab/sessions.json" ]; then
    json=$(cat "lab/sessions.json" 2>/dev/null || echo "{}")
  else
    json=$(git show origin/main:lab/sessions.json 2>/dev/null || echo "{}")
  fi

  for persona in "${PERSONAS[@]}"; do
    local branch
    branch=$(echo "$json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
info = data.get('$persona', {})
print(info.get('branch', ''))
" 2>/dev/null || echo "")
    if [ -n "$branch" ]; then
      BRANCH_MAP[$persona]="$branch"
    fi
  done
}

branch_for() {
  echo "${BRANCH_MAP[$1]:-}"
}

# ── Helpers ──────────────────────────────────────────────────────────────────

fetch_refs() {
  git fetch "$REPO_URL" '+refs/heads/*:refs/remotes/lab/*' --quiet 2>/dev/null || true
}

# ── Identity ─────────────────────────────────────────────────────────────────

SESSION_FILE=".lab_session"

cmd_login() {
  local persona="${1:?Usage: lab login <your-persona>}"
  local valid=false
  for p in "${PERSONAS[@]}"; do
    if [ "$p" = "$persona" ]; then
      valid=true
      break
    fi
  done
  if [ "$valid" = false ]; then
    echo "ERROR: Unknown persona '${persona}'."
    echo "Valid: ${PERSONAS[*]}"
    exit 1
  fi
  echo "$persona" > "$SESSION_FILE"
  echo "Logged in as: ${persona}"
}

whoami_persona() {
  if [ ! -f "$SESSION_FILE" ]; then
    echo "ERROR: Not logged in. Run: tools/lab login <your-persona>" >&2
    exit 1
  fi
  cat "$SESSION_FILE" | tr -d '[:space:]'
}

# ── Sync from main ───────────────────────────────────────────────────────────

sync_from_main() {
  local me
  me=$(cat "$SESSION_FILE" 2>/dev/null | tr -d '[:space:]' || true)

  fetch_refs
  load_branches

  # 1. Sync sessions.json from main
  mkdir -p lab
  git show "lab/main:lab/sessions.json" > "lab/sessions.json" 2>/dev/null || true

  # 2. Sync today's heartbeat log from main
  local hb_date
  hb_date=$(date -u +%Y-%m-%d)
  mkdir -p lab/heartbeats
  git show "lab/main:lab/heartbeats/${hb_date}.md" > "lab/heartbeats/${hb_date}.md" 2>/dev/null || true

  # 3. Sync inbox from main (if logged in)
  if [ -n "$me" ]; then
    local inbox_path="lab/mail/${me}/inbox"
    mkdir -p "$inbox_path"

    local main_files
    main_files=$(git ls-tree --name-only "lab/main" "${inbox_path}/" 2>/dev/null || true)

    if [ -n "$main_files" ]; then
      local synced=0
      while IFS= read -r filepath; do
        local filename
        filename=$(basename "$filepath")
        [[ "$filename" == .* ]] && continue
        if [ ! -f "$filepath" ]; then
          git show "lab/main:${filepath}" > "$filepath" 2>/dev/null && synced=$((synced + 1))
        fi
      done <<< "$main_files"

      # Merge .mh_sequences (union unseen from main into local)
      if git show "lab/main:${inbox_path}/.mh_sequences" > /dev/null 2>&1; then
        local main_seq="/tmp/lab_mh_seq_main_$$"
        git show "lab/main:${inbox_path}/.mh_sequences" > "$main_seq" 2>/dev/null
        if [ -f "${inbox_path}/.mh_sequences" ]; then
          python3 -c "
import sys
from pathlib import Path

main_path, local_path = sys.argv[1], sys.argv[2]

def parse_seq(path):
    seqs = {}
    for line in Path(path).read_text().splitlines():
        if ':' in line:
            name, vals = line.split(':', 1)
            seqs[name.strip()] = set(vals.strip().split())
    return seqs

main_seqs = parse_seq(main_path)
local_seqs = parse_seq(local_path)

for key in main_seqs:
    if key in local_seqs:
        local_seqs[key] = local_seqs[key] | main_seqs[key]
    else:
        local_seqs[key] = main_seqs[key]

with open(local_path, 'w') as f:
    for key, vals in sorted(local_seqs.items()):
        f.write(f'{key}: {\" \".join(sorted(vals, key=int))}\\n')
" "$main_seq" "${inbox_path}/.mh_sequences"
        else
          cp "$main_seq" "${inbox_path}/.mh_sequences"
        fi
        rm -f "$main_seq"
      fi

      if [ "$synced" -gt 0 ]; then
        echo "  Synced ${synced} new mail message(s)"
      fi
    fi
  fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_sync() {
  local me
  me=$(whoami_persona)

  echo "=== Lab Sync ==="
  echo ""

  sync_from_main

  # Show heartbeat info
  local hb_date
  hb_date=$(date -u +%Y-%m-%d)
  local hb_log="lab/heartbeats/${hb_date}.md"
  local hb_count=0
  if [ -f "$hb_log" ]; then
    hb_count=$(grep -c "^## Heartbeat #" "$hb_log" 2>/dev/null || echo 0)
  fi
  echo "  Heartbeat round: #${hb_count}"
  echo ""

  # Clone each persona's branch into workspace (shallow, single-branch).
  # No merge commits — your branch stays clean with only your own work.
  local ws="lab/${me}/workspace"
  mkdir -p "$ws"

  for persona in "${PERSONAS[@]}"; do
    [ "$persona" = "$me" ] && continue

    local branch
    branch=$(branch_for "$persona")
    if [ -z "$branch" ]; then
      echo "  ${persona}: no active session"
      continue
    fi

    local persona_ws="${ws}/${persona}"

    # Fresh shallow clone each time (fast — depth 1, single branch)
    rm -rf "$persona_ws"

    if git clone --depth 1 --single-branch -b "$branch" "$REPO_URL" "$persona_ws" --quiet 2>/dev/null; then
      local last_commit
      last_commit=$(git -C "$persona_ws" log -1 --format="%h %s" 2>/dev/null || echo "unknown")
      echo "  ${persona}: synced  ${last_commit}"
    else
      echo "  ${persona}: branch ${branch} (not available)"
    fi
  done

  echo ""
  echo "  Other personas' files are in: lab/${me}/workspace/{persona}/"

  # ── Colab merge: auto-merge annotations from other personas ──
  echo ""
  echo "  Checking colab annotations..."

  local merged_file="lab/notes/${me}/.merged_colab"
  mkdir -p "lab/notes/${me}"
  touch "$merged_file"

  local colab_count=0

  for annotator in "${PERSONAS[@]}"; do
    [ "$annotator" = "$me" ] && continue

    local colab_dir="${ws}/${annotator}/lab/${annotator}/colab"
    [ -d "$colab_dir" ] || continue

    for colab_file in "${colab_dir}"/*.tex; do
      [ -f "$colab_file" ] || continue

      local filename
      filename=$(basename "$colab_file")
      local my_paper="lab/${filename}"

      # Only merge if it's one of our papers
      [ -f "$my_paper" ] || continue

      # Dedup by content hash — skip if already merged this version
      local colab_hash
      colab_hash=$(git hash-object "$colab_file" 2>/dev/null || echo "unknown")
      local merge_key="${annotator}:${filename}:${colab_hash}"
      if grep -qxF "$merge_key" "$merged_file" 2>/dev/null; then
        continue
      fi

      # 3-way merge: base = original in annotator's branch, ours = our version, theirs = colab
      local base="${ws}/${annotator}/lab/${filename}"
      if [ ! -f "$base" ]; then
        echo "    WARNING: base not found for ${filename} in ${annotator}'s branch"
        echo "$merge_key" >> "$merged_file"
        continue
      fi

      # Backup before merge
      cp "$my_paper" "${my_paper}.pre-colab"

      if git merge-file "$my_paper" "$base" "$colab_file" 2>/dev/null; then
        echo "    ${annotator}: merged colab annotations into ${filename}"
        rm -f "${my_paper}.pre-colab"
        colab_count=$((colab_count + 1))
      else
        # Conflict — revert and auto-send mail
        cp "${my_paper}.pre-colab" "$my_paper"
        rm -f "${my_paper}.pre-colab"
        echo "    ${annotator}: CONFLICT on ${filename} — sending notification"

        # Auto-send conflict mail
        local outbox="lab/mail/${me}/outbox"
        mkdir -p "$outbox"
        local next_num=1
        for f in "$outbox"/*; do
          [ -f "$f" ] || continue
          local n
          n=$(basename "$f")
          [[ "$n" =~ ^[0-9]+$ ]] || continue
          [ "$n" -ge "$next_num" ] && next_num=$((n + 1))
        done

        cat > "${outbox}/${next_num}" <<MAIL
From: ${me}
To: ${annotator}
Subject: Colab merge conflict on ${filename}
Date: $(date -u -R)

Your colab annotations on ${filename} could not be merged automatically
(conflict with my latest changes). Please re-sync and update your
colab copy at lab/${annotator}/colab/${filename}.
MAIL
      fi

      echo "$merge_key" >> "$merged_file"
    done
  done

  if [ "$colab_count" -gt 0 ]; then
    echo ""
    echo "  ${colab_count} colab annotation(s) merged. Review and commit."
  fi
}

cmd_mail() {
  # Delegate to Python for MH mailbox operations
  local subcmd="${1:-list}"
  shift 2>/dev/null || true
  python3 tools/lab-mail "$subcmd" "$@"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  login)         cmd_login "${2:-}" ;;
  sync)          cmd_sync ;;
  mail)          shift; cmd_mail "$@" ;;
  *)
    echo "Usage: tools/lab <command> [args]"
    echo ""
    echo "  login <persona>     Log in as a persona (required first)"
    echo "  sync                Sync: clone branches + merge colab annotations + inbox"
    echo "  mail                List inbox messages"
    echo "  mail read <num>     Read a message (marks as seen)"
    echo "  mail status         Show inbox/outbox summary"
    exit 1
    ;;
esac
