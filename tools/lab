#!/usr/bin/env bash
# lab — Unified tool for Rosencrantz Lab personas.
#
# Usage inside a Jules session (after login):
#   tools/lab login <persona>        Log in as a persona (required first)
#   tools/lab sync                   Clone all persona branches into workspace + inbox from main
#   tools/lab mail                   List inbox messages
#   tools/lab mail read <num>        Read a message (marks as seen)
#   tools/lab mail status            Show inbox/outbox summary
#
# Sync clones each persona's branch (shallow, single-branch) into
# workspace/{persona}/ (gitignored), then auto-merges any colab
# annotations on your papers. No merge commits — your branch stays clean.
# Branch discovery via lab/sessions.json from main (written by heartbeat.py).
set -euo pipefail

# Detect Python binary (python3 on Linux/Jules, python on Windows)
PYTHON_BIN="python3"
if ! command -v "$PYTHON_BIN" &>/dev/null; then
  PYTHON_BIN="python"
fi
if ! command -v "$PYTHON_BIN" &>/dev/null; then
  echo "WARNING: Python not found (tried python3 and python). Mail features disabled." >&2
  PYTHON_BIN=""
fi

REPO="franklinbaldo/rosencrantz-coin"
REPO_URL="https://github.com/${REPO}.git"

# Discover personas dynamically from lab/*/SOUL.md (sorted alphabetically)
PERSONAS=()
for _soul in lab/*/SOUL.md; do
  [ -f "$_soul" ] || continue
  PERSONAS+=("$(basename "$(dirname "$_soul")")")
done
IFS=$'\n' PERSONAS=($(printf '%s\n' "${PERSONAS[@]}" | sort)); unset IFS

if [ ${#PERSONAS[@]} -eq 0 ]; then
  echo "ERROR: No personas found in lab/*/SOUL.md" >&2
  exit 1
fi

# ── Branch discovery via sessions.json ────────────────────────────────────────

declare -A BRANCH_MAP

load_branches() {
  local json=""
  if [ -f "lab/sessions.json" ]; then
    json=$(cat "lab/sessions.json" 2>/dev/null || echo "{}")
  else
    json=$(git show origin/main:lab/sessions.json 2>/dev/null || echo "{}")
  fi

  for persona in "${PERSONAS[@]}"; do
    local branch
    branch=$(echo "$json" | ${PYTHON_BIN:-python3} -c "
import json, sys
data = json.load(sys.stdin)
info = data.get('$persona', {})
print(info.get('branch', ''))
" 2>/dev/null || echo "")
    if [ -n "$branch" ]; then
      BRANCH_MAP[$persona]="$branch"
    fi
  done
}

branch_for() {
  echo "${BRANCH_MAP[$1]:-}"
}

# ── Helpers ──────────────────────────────────────────────────────────────────

fetch_main() {
  git fetch "$REPO_URL" '+refs/heads/main:refs/remotes/lab/main' --quiet 2>/dev/null || true
}

# ── Identity ─────────────────────────────────────────────────────────────────

SESSION_FILE=".lab_session"

cmd_login() {
  local persona="${1:?Usage: lab login <your-persona>}"
  if [[ ! " ${PERSONAS[*]} " =~ " ${persona} " ]]; then
    echo "ERROR: Unknown persona '${persona}'. Valid: ${PERSONAS[*]}"
    exit 1
  fi
  echo "$persona" > "$SESSION_FILE"
  echo "Logged in as: ${persona}"
}

whoami_persona() {
  if [ ! -f "$SESSION_FILE" ]; then
    echo "ERROR: Not logged in. Run: tools/lab login <your-persona>" >&2
    exit 1
  fi
  cat "$SESSION_FILE" | tr -d '[:space:]'
}

# ── Sync from main ───────────────────────────────────────────────────────────

sync_from_main() {
  local me
  me=$(cat "$SESSION_FILE" 2>/dev/null | tr -d '[:space:]' || true)

  fetch_main

  # 1. Sync sessions.json from main (before load_branches reads it)
  mkdir -p lab
  git show "lab/main:lab/sessions.json" > "lab/sessions.json" 2>/dev/null || true

  load_branches

  # 2. Heartbeat logs are read-only (managed by CI on main). Do NOT write them
  #    to the persona branch — that causes guaranteed merge conflicts.

  # 3. Sync inbox from main (if logged in)
  if [ -n "$me" ]; then
    local inbox_path="lab/${me}/mail/inbox"
    mkdir -p "$inbox_path"

    local main_files
    main_files=$(git ls-tree --name-only "lab/main" "${inbox_path}/" 2>/dev/null || true)

    if [ -n "$main_files" ]; then
      local new_keys=""
      while IFS= read -r filepath; do
        local filename
        filename=$(basename "$filepath")
        [[ "$filename" == .* ]] && continue
        if [ ! -f "$filepath" ]; then
          git show "lab/main:${filepath}" > "$filepath" 2>/dev/null && new_keys="${new_keys} ${filename}"
        fi
      done <<< "$main_files"

      # Mark only newly synced messages as unseen (don't re-add read ones)
      if [ -n "$new_keys" ] && [ -n "$PYTHON_BIN" ]; then
        $PYTHON_BIN -c "
import sys; from pathlib import Path
seq_file, new = Path(sys.argv[1]), sys.argv[2].split()
seqs = {}
if seq_file.exists():
    for line in seq_file.read_text().splitlines():
        if ':' in line:
            k, v = line.split(':', 1)
            seqs[k.strip()] = v.strip().split()
unseen = set(seqs.get('unseen', [])); unseen.update(new)
seqs['unseen'] = sorted(unseen, key=int)
seq_file.write_text(''.join(f'{k}: {\" \".join(v)}\n' for k, v in sorted(seqs.items())))
" "${inbox_path}/.mh_sequences" "$new_keys"
        local count
        count=$(echo $new_keys | wc -w)
        echo "  Synced ${count} new mail message(s)"
      fi
    fi
  fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_sync() {
  local me
  me=$(whoami_persona)

  # Log sync output to file (tee through the whole function)
  local sync_log="lab/${me}/logs/.last_sync.log"
  mkdir -p "lab/${me}/logs"

  _sync_inner "$me" 2>&1 | tee "$sync_log"
}

_sync_inner() {
  local me="$1"

  echo "=== Lab Sync ==="
  echo ""

  # Track notifications
  local notifications=()

  sync_from_main

  # Show heartbeat info (read from main ref, not disk — avoids conflict)
  local hb_date
  hb_date=$(date -u +%Y-%m-%d)
  local hb_count=0
  hb_count=$(git show "lab/main:lab/heartbeats/${hb_date}.md" 2>/dev/null | grep -c "^## Heartbeat #" || echo 0)
  echo "  Heartbeat round: #${hb_count}"
  echo ""

  # Count new mail (from sync_from_main output — check inbox unseen)
  local unseen_count=0
  local seq_file="lab/${me}/mail/inbox/.mh_sequences"
  if [ -f "$seq_file" ] && [ -n "$PYTHON_BIN" ]; then
    unseen_count=$($PYTHON_BIN -c "
from pathlib import Path
seqs = {}
for line in Path('$seq_file').read_text().splitlines():
    if ':' in line:
        k, v = line.split(':', 1)
        seqs[k.strip()] = v.strip().split()
print(len(seqs.get('unseen', [])))
" 2>/dev/null || echo 0)
  fi
  if [ "$unseen_count" -gt 0 ]; then
    notifications+=("You have ${unseen_count} unread mail message(s) — run: tools/lab mail")
  fi

  # Clone each persona's branch into workspace (shallow, single-branch).
  # No merge commits — your branch stays clean with only your own work.
  local ws="workspace"
  mkdir -p "$ws"

  local new_papers=()

  for persona in "${PERSONAS[@]}"; do
    [ "$persona" = "$me" ] && continue

    local branch
    branch=$(branch_for "$persona")
    if [ -z "$branch" ]; then
      echo "  ${persona}: no active session"
      continue
    fi

    local persona_ws="${ws}/${persona}"

    # Fresh shallow clone each time (fast — depth 1, single branch)
    rm -rf "$persona_ws"

    if git clone --depth 1 --single-branch -b "$branch" "$REPO_URL" "$persona_ws" --quiet 2>/dev/null; then
      local last_commit
      last_commit=$(git -C "$persona_ws" log -1 --format="%h %s" 2>/dev/null || echo "unknown")
      echo "  ${persona}: synced  ${last_commit}"

      # Detect new papers in this persona's colab
      local colab_dir="${persona_ws}/lab/${persona}/colab"
      if [ -d "$colab_dir" ]; then
        for tex_file in "${colab_dir}"/*.tex; do
          [ -f "$tex_file" ] || continue
          new_papers+=("${persona}: $(basename "$tex_file")")
        done
      fi
    else
      echo "  ${persona}: branch ${branch} (not available)"
    fi
  done

  echo ""
  echo "  Other personas' files are in: workspace/{persona}/"

  # ── Colab merge: auto-merge annotations from other personas ──
  echo ""
  echo "  Checking colab annotations..."

  local merged_file="lab/${me}/colab/.merged_colab"
  mkdir -p "lab/${me}/colab"
  touch "$merged_file"

  local colab_count=0

  for annotator in "${PERSONAS[@]}"; do
    [ "$annotator" = "$me" ] && continue

    local colab_dir="${ws}/${annotator}/lab/${annotator}/colab"
    [ -d "$colab_dir" ] || continue

    for colab_file in "${colab_dir}"/*.tex; do
      [ -f "$colab_file" ] || continue

      local filename
      filename=$(basename "$colab_file")
      local my_paper="lab/${me}/colab/${filename}"

      # Only merge if it's one of our papers
      [ -f "$my_paper" ] || continue

      # Dedup by content hash — skip if already merged this version
      local colab_hash
      colab_hash=$(git hash-object "$colab_file" 2>/dev/null || echo "unknown")
      local merge_key="${annotator}:${filename}:${colab_hash}"
      if grep -qxF "$merge_key" "$merged_file" 2>/dev/null; then
        continue
      fi

      # 3-way merge: base = our paper on annotator's branch (untouched per golden rule)
      local base="${ws}/${annotator}/lab/${me}/colab/${filename}"
      if [ ! -f "$base" ]; then
        echo "    WARNING: base not found for ${filename} in ${annotator}'s branch"
        echo "$merge_key" >> "$merged_file"
        continue
      fi

      # Guard: skip merge if annotator's version is a pure deletion (empty or gutted)
      local my_lines colab_lines
      my_lines=$(wc -l < "$my_paper" 2>/dev/null || echo 0)
      colab_lines=$(wc -l < "$colab_file" 2>/dev/null || echo 0)
      if [ "$colab_lines" -eq 0 ]; then
        echo "    ${annotator}: SKIPPED ${filename} — annotator's version is empty (pure deletion)"
        notifications+=("WARNING: ${annotator}'s colab copy of ${filename} is empty — possible accidental deletion, not merged")
        echo "$merge_key" >> "$merged_file"
        continue
      fi

      # Backup before merge
      cp "$my_paper" "${my_paper}.pre-colab"

      if git merge-file "$my_paper" "$base" "$colab_file" 2>/dev/null; then
        echo "    ${annotator}: merged colab annotations into ${filename}"
        rm -f "${my_paper}.pre-colab"
        colab_count=$((colab_count + 1))
        notifications+=("COLAB: ${annotator} annotated your paper ${filename} — review the merged changes")
      else
        # Conflict — keep both versions with conflict markers for manual reconciliation
        rm -f "${my_paper}.pre-colab"
        echo "    ${annotator}: CONFLICT on ${filename} — both versions kept, please reconcile"
        colab_count=$((colab_count + 1))
        notifications+=("CONFLICT: ${annotator}'s annotations on ${filename} have conflicts — read git log and reconcile the conflict markers in your paper")
      fi

      echo "$merge_key" >> "$merged_file"
    done
  done

  if [ "$colab_count" -gt 0 ]; then
    echo ""
    echo "  ${colab_count} colab annotation(s) merged. Review and commit."
  fi

  # Check for unclaimed RFEs relevant to this persona
  local rfe_count=0
  for rfe_file in lab/*/experiments/*/rfe.md; do
    [ -f "$rfe_file" ] || continue
    # Skip own RFEs
    [[ "$rfe_file" == *"lab/${me}/"* ]] && continue
    # Check if unclaimed (has "[ ] Filed" or "[ ] Claimed")
    if grep -q "\[ \] Filed" "$rfe_file" 2>/dev/null; then
      rfe_count=$((rfe_count + 1))
    fi
  done
  if [ "$rfe_count" -gt 0 ]; then
    notifications+=("${rfe_count} unclaimed RFE(s) from other personas — check lab/*/experiments/*/rfe.md")
  fi

  # ── Notifications summary ──
  echo ""
  echo "========================================"
  echo "  NOTIFICATIONS"
  echo "========================================"
  if [ ${#notifications[@]} -eq 0 ]; then
    echo "  (none)"
  else
    for note in "${notifications[@]}"; do
      echo "  * ${note}"
    done
  fi
  echo "========================================"
}

cmd_mail() {
  if [ -z "$PYTHON_BIN" ]; then
    echo "ERROR: Python not found. Mail requires Python." >&2
    exit 1
  fi
  local subcmd="${1:-list}"
  shift 2>/dev/null || true
  $PYTHON_BIN tools/lab-mail "$subcmd" "$@"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  login)         cmd_login "${2:-}" ;;
  sync)          cmd_sync ;;
  mail)          shift; cmd_mail "$@" ;;
  *)
    echo "Usage: tools/lab <command> [args]"
    echo ""
    echo "  login <persona>     Log in as a persona (required first)"
    echo "  sync                Sync: clone branches + merge colab annotations + inbox"
    echo "  mail                List inbox messages"
    echo "  mail read <num>     Read a message (marks as seen)"
    echo "  mail status         Show inbox/outbox summary"
    exit 1
    ;;
esac
