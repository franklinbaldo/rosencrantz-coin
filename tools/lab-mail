#!/usr/bin/env python3
"""lab-mail — MH mailbox backend for tools/lab mail commands.

Internal module called by tools/lab. Not invoked directly by personas.
"""

import email
import email.message
import mailbox
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

PERSONAS = sorted(p.parent.name for p in Path("lab").glob("*/SOUL.md"))
REPO = "franklinbaldo/rosencrantz-coin"
SESSION_FILE = ".lab_session"


def whoami():
    """Read logged-in persona from .lab_session (written by tools/lab login)."""
    p = Path(SESSION_FILE)
    if not p.exists():
        return None
    return p.read_text(encoding="utf-8").strip() or None


def today():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")



def get_mh(persona, box="inbox"):
    """Get or create an MH mailbox for a persona."""
    path = Path(f"lab/{persona}/mail/{box}")
    path.mkdir(parents=True, exist_ok=True)
    return mailbox.MH(str(path), create=True)



def now_stamp():
    return datetime.now(timezone.utc).strftime("%a, %d %b %Y %H:%M:%S +0000")


def dedup_key(msg):
    """Create a deduplication key from message headers."""
    return f"{msg.get('From', '')}|{msg.get('Subject', '')}|{msg.get('Date', '')}"


def make_message(sender, recipient, subject, body):
    """Create a properly formatted email message."""
    msg = mailbox.MHMessage()
    msg["From"] = sender
    msg["To"] = recipient
    msg["Subject"] = subject
    msg["Date"] = now_stamp()
    msg["X-Lab-Date"] = today()
    msg.set_payload(body)
    return msg


def parse_send_args(args):
    """Parse -s <subject> and -b <body> from argument list."""
    subject = "No subject"
    body = None

    if "-s" in args:
        s_idx = args.index("-s")
        if s_idx + 1 < len(args):
            subject = args[s_idx + 1]

    if "-b" in args:
        b_idx = args.index("-b")
        body_parts = []
        i = b_idx + 1
        while i < len(args):
            body_parts.append(args[i])
            i += 1
        body = " ".join(body_parts) if body_parts else ""

    return subject, body


# ── Persona commands ─────────────────────────────────────────────────────────


def cmd_send(me, args):
    """Send a message to another persona via your outbox."""
    if len(args) < 3 or "-s" not in args:
        print("Usage: tools/lab mail send <recipient> -s <subject> [-b <body>]")
        print(f"  Recipients: {', '.join(p for p in PERSONAS if p != me)}")
        sys.exit(1)

    recipient = args[0]
    if recipient not in PERSONAS:
        print(f"ERROR: Unknown persona '{recipient}'.")
        print(f"  Valid recipients: {', '.join(p for p in PERSONAS if p != me)}")
        sys.exit(1)
    if recipient == me:
        print("ERROR: Cannot send mail to yourself.")
        sys.exit(1)

    subject, body = parse_send_args(args[1:])
    if body is None:
        body = ""

    msg = make_message(me, recipient, subject, body)
    outbox = get_mh(me, "outbox")
    key = outbox.add(msg)
    outbox.flush()
    outbox.close()

    print(f"Queued message #{key} to {recipient}")
    print(f"  Subject: {subject}")
    print(f"  Commit and the heartbeat will deliver it.")


def cmd_reply(me, args):
    """Reply to an inbox message."""
    if not args:
        print("Usage: tools/lab mail reply <message-number> [-b <body>]")
        sys.exit(1)

    try:
        key = int(args[0])
    except ValueError:
        print(f"ERROR: '{args[0]}' is not a valid message number.")
        sys.exit(1)

    inbox = get_mh(me, "inbox")
    try:
        orig = inbox[key]
    except KeyError:
        print(f"ERROR: No message #{key} in inbox.")
        inbox.close()
        sys.exit(1)

    sender = orig.get("From", "")
    if sender not in PERSONAS:
        print(f"ERROR: Original sender '{sender}' is not a known persona.")
        inbox.close()
        sys.exit(1)

    orig_subject = orig.get("Subject", "")
    subject = f"Re: {orig_subject}" if not orig_subject.startswith("Re: ") else orig_subject

    _, body = parse_send_args(args[1:])
    if body is None:
        body = ""

    orig_body = orig.get_payload() or ""
    if orig_body:
        quoted = "\n".join(f"> {line}" for line in orig_body.splitlines())
        if body:
            body = f"{body}\n\n{quoted}"
        else:
            body = f"(empty reply)\n\n{quoted}"

    msg = make_message(me, sender, subject, body)
    outbox = get_mh(me, "outbox")
    out_key = outbox.add(msg)
    outbox.flush()
    outbox.close()

    # Mark original as replied
    sequences = inbox.get_sequences()
    replied = list(sequences.get("replied", []))
    if key not in replied:
        replied.append(key)
        sequences["replied"] = sorted(replied)
        inbox.set_sequences(sequences)
    inbox.flush()
    inbox.close()

    print(f"Queued reply #{out_key} to {sender}")
    print(f"  Subject: {subject}")
    print(f"  Commit and the heartbeat will deliver it.")


def cmd_broadcast(me, args):
    """Send a message to all other personas."""
    if "-s" not in args:
        print("Usage: tools/lab mail broadcast -s <subject> [-b <body>]")
        sys.exit(1)

    subject, body = parse_send_args(args)
    if body is None:
        body = ""

    outbox = get_mh(me, "outbox")
    recipients = [p for p in PERSONAS if p != me]
    for recipient in recipients:
        msg = make_message(me, recipient, subject, body)
        outbox.add(msg)
    outbox.flush()
    outbox.close()

    print(f"Queued broadcast to {len(recipients)} personas: {', '.join(recipients)}")
    print(f"  Subject: {subject}")
    print(f"  Commit and the heartbeat will deliver it.")


def cmd_list(me, _args):
    """List inbox messages with unseen markers."""

    inbox = get_mh(me, "inbox")
    keys = inbox.keys()

    if not keys:
        print(f"Inbox empty (lab/{me}/mail/inbox/)")
        inbox.close()
        return

    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))

    print(f"=== Inbox for {me} ({len(keys)} messages, {len(unseen)} unseen) ===\n")
    for key in sorted(keys):
        msg = inbox[key]
        marker = " *" if key in unseen else "  "
        sender = msg.get("From", "?")
        subject = msg.get("Subject", "(no subject)")
        date = msg.get("X-Lab-Date", msg.get("Date", "?"))
        replied = key in set(sequences.get("replied", []))
        r_marker = " [replied]" if replied else ""
        print(f"  {marker} #{key}  {sender:10s}  {subject}{r_marker}")

    inbox.close()
    print(f"\nRead:  tools/lab mail read <number>")
    print(f"Reply: tools/lab mail reply <number> -b \"your response\"")


def cmd_read(me, args):
    """Read a message and mark as seen."""

    if not args:
        print("Usage: lab-mail read <message-number>")
        sys.exit(1)

    try:
        key = int(args[0])
    except ValueError:
        print(f"ERROR: '{args[0]}' is not a valid message number.")
        sys.exit(1)

    inbox = get_mh(me, "inbox")
    try:
        msg = inbox[key]
    except KeyError:
        print(f"ERROR: No message #{key} in inbox.")
        inbox.close()
        sys.exit(1)

    # Display
    print(f"From: {msg.get('From', '?')}")
    print(f"To: {msg.get('To', '?')}")
    print(f"Subject: {msg.get('Subject', '?')}")
    print(f"Date: {msg.get('Date', '?')}")
    print("---")
    print(msg.get_payload())

    # Mark as seen (remove from unseen sequence)
    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))
    if key in unseen:
        unseen.discard(key)
        sequences["unseen"] = sorted(unseen)
        inbox.set_sequences(sequences)

    inbox.flush()
    inbox.close()

    # Hint about reply
    sender = msg.get("From", "")
    if sender in PERSONAS:
        print(f"\nReply: tools/lab mail reply {key} -b \"your response\"")


def cmd_status(me, _args):
    """Show inbox/outbox summary."""

    inbox = get_mh(me, "inbox")
    outbox = get_mh(me, "outbox")

    inbox_keys = inbox.keys()
    outbox_keys = outbox.keys()
    sequences = inbox.get_sequences()
    unseen = len(sequences.get("unseen", []))

    print(f"=== Mail for {me} ===")
    print(f"  Inbox:  {len(inbox_keys)} ({unseen} unseen)")
    print(f"  Outbox: {len(outbox_keys)} queued")

    if unseen > 0:
        print(f"\n  Unseen:")
        for key in sequences.get("unseen", [])[:5]:
            msg = inbox[key]
            print(f"    #{key} from {msg.get('From', '?')}: {msg.get('Subject', '?')}")
        if unseen > 5:
            print(f"    ... and {unseen - 5} more")

    inbox.close()
    outbox.close()

    print(f"\nQuick commands:")
    print(f"  tools/lab mail list              List all messages")
    print(f"  tools/lab mail read <num>        Read a message")
    print(f"  tools/lab mail reply <num> -b .. Reply to a message")


# ── Heartbeat command (central delivery) ─────────────────────────────────────

def load_session_branches():
    """Load persona -> branch mapping from lab/sessions.json."""
    sessions_file = Path("lab/sessions.json")
    if not sessions_file.exists():
        return {}
    try:
        import json as _json
        data = _json.loads(sessions_file.read_text(encoding="utf-8"))
        return {p: info["branch"] for p, info in data.items() if info.get("branch")}
    except Exception:
        return {}


def cmd_deliver(_args):
    """Scan all persona branches and deliver outbox messages to inboxes on main.

    Called by the heartbeat workflow running on main.
    """
    print(f"=== Mail delivery — {today()} ===\n")

    branches = load_session_branches()
    if not branches:
        print("  (no sessions.json or no active branches)")
        return

    # Fetch all remote branches
    subprocess.run(
        ["git", "fetch", f"https://github.com/{REPO}.git",
         "+refs/heads/*:refs/remotes/lab/*"],
        capture_output=True,
    )

    total_delivered = 0

    for sender in PERSONAS:
        branch = branches.get(sender)
        if not branch:
            continue
        ref = f"lab/{branch}"

        # Check if branch exists
        result = subprocess.run(
            ["git", "rev-parse", "--verify", ref],
            capture_output=True,
        )
        if result.returncode != 0:
            continue

        # List files in sender's outbox
        outbox_path = f"lab/{sender}/mail/outbox"
        result = subprocess.run(
            ["git", "ls-tree", "--name-only", ref, f"{outbox_path}/"],
            capture_output=True, text=True,
        )
        if result.returncode != 0 or not result.stdout.strip():
            continue

        for filepath in result.stdout.strip().splitlines():
            filename = os.path.basename(filepath)
            if filename.startswith("."):
                continue

            # Read message content from branch
            cat_result = subprocess.run(
                ["git", "show", f"{ref}:{filepath}"],
                capture_output=True, text=True,
            )
            if cat_result.returncode != 0:
                continue

            content = cat_result.stdout

            # Parse email
            try:
                msg = email.message_from_string(content)
            except Exception:
                continue

            recipient = msg.get("To", "")
            if recipient not in PERSONAS or recipient == sender:
                continue

            # Open recipient's inbox and check for duplicates
            inbox = get_mh(recipient, "inbox")
            existing_keys = set()
            for k in inbox.keys():
                existing_keys.add(dedup_key(inbox[k]))

            msg_key = dedup_key(msg)
            if msg_key in existing_keys:
                inbox.close()
                continue

            # Deliver
            mh_msg = mailbox.MHMessage(content)
            new_key = inbox.add(mh_msg)

            # Add to unseen sequence
            sequences = inbox.get_sequences()
            unseen = list(sequences.get("unseen", []))
            unseen.append(new_key)
            sequences["unseen"] = sorted(unseen)
            inbox.set_sequences(sequences)

            inbox.flush()
            inbox.close()

            subject = msg.get("Subject", "(no subject)")
            print(f"  {sender} → {recipient}: {subject}")
            total_delivered += 1

    if total_delivered == 0:
        print("  (no new mail to deliver)")
    else:
        print(f"\n  {total_delivered} message(s) delivered")


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print("Usage: tools/lab mail [send|reply|broadcast|list|read|status|deliver]")
        sys.exit(1)

    cmd = sys.argv[1]

    # 'deliver' runs on main (no persona needed)
    if cmd == "deliver":
        cmd_deliver(sys.argv[2:])
        return

    persona_commands = {
        "send": cmd_send,
        "reply": cmd_reply,
        "broadcast": cmd_broadcast,
        "list": cmd_list,
        "read": cmd_read,
        "status": cmd_status,
    }

    if cmd not in persona_commands:
        print(f"Unknown mail command: {cmd}")
        print(f"Available: {', '.join(persona_commands)}, deliver")
        sys.exit(1)

    me = whoami()
    if not me:
        print("ERROR: Not logged in. Run: tools/lab login <your-persona>")
        sys.exit(1)

    persona_commands[cmd](me, sys.argv[2:])


if __name__ == "__main__":
    main()
