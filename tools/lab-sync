#!/usr/bin/env bash
# lab-sync — Cross-persona sync tool for Rosencrantz Lab.
#
# Usage inside a Jules session:
#   tools/lab-sync status              List persona branches + latest commits
#   tools/lab-sync diff <persona>      Show what <persona> changed vs main
#   tools/lab-sync read <persona> <f>  Fetch a file from <persona>'s branch (read-only)
#   tools/lab-sync browse <persona>    List files changed by <persona> with raw URLs
#   tools/lab-sync annotate <paper>    Fetch a paper for annotation (saves editable copy)
#   tools/lab-sync apply-patches       Apply pending annotations from other personas
#   tools/lab-sync mail                List inbox (mail delivered by heartbeat on main)
#
# Branch discovery: reads lab/sessions.json from main (written by heartbeat.py).
# Files fetched via 'read' are saved locally but added to .gitignore
# so they are never committed to your branch.
set -euo pipefail

REPO="franklinbaldo/rosencrantz-coin"
REPO_URL="https://github.com/${REPO}.git"
RAW_URL="https://raw.githubusercontent.com/${REPO}"
PERSONAS=(baldo scott sabine pearl fuchs liang wolfram mycroft giles)

# ── Branch discovery via sessions.json ────────────────────────────────────────

declare -A BRANCH_MAP

load_branches() {
  # Fetch sessions.json from main via raw GitHub URL
  local json
  json=$(curl -sf "${RAW_URL}/main/lab/sessions.json" 2>/dev/null || echo "{}")

  for persona in "${PERSONAS[@]}"; do
    local branch
    branch=$(echo "$json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
info = data.get('$persona', {})
print(info.get('branch', ''))
" 2>/dev/null || echo "")
    if [ -n "$branch" ]; then
      BRANCH_MAP[$persona]="$branch"
    fi
  done
}

branch_for() {
  echo "${BRANCH_MAP[$1]:-}"
}

# ── Helpers ──────────────────────────────────────────────────────────────────

fetch_refs() {
  git fetch "$REPO_URL" '+refs/heads/*:refs/remotes/lab/*' --quiet 2>/dev/null || true
}

ref_exists() {
  git rev-parse --verify "lab/$1" >/dev/null 2>&1
}

raw_url_for() {
  local persona="$1" filepath="$2"
  local branch
  branch=$(branch_for "$persona")
  echo "${RAW_URL}/${branch}/${filepath}"
}

# Ensure a path is in .gitignore (idempotent)
gitignore_add() {
  local path="$1"
  local marker="# lab-sync read-only"
  if [ ! -f .gitignore ]; then
    echo "$marker" > .gitignore
    echo "$path" >> .gitignore
    return
  fi
  if ! grep -qxF "$path" .gitignore 2>/dev/null; then
    # Add marker section if not present
    if ! grep -qF "$marker" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "$marker" >> .gitignore
    fi
    echo "$path" >> .gitignore
  fi
}

# Detect current persona from branch name.
# Strategy: check sessions.json for branch match, then fall back to name substring.
detect_persona() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  [ -z "$branch" ] && { echo ""; return; }

  # 1) Reverse-lookup: find persona whose session branch matches ours
  if [ ${#BRANCH_MAP[@]} -gt 0 ]; then
    for p in "${PERSONAS[@]}"; do
      if [ "${BRANCH_MAP[$p]:-}" = "$branch" ]; then
        echo "$p"
        return
      fi
    done
  fi

  # 2) Fallback: persona name appears anywhere in branch name
  for p in "${PERSONAS[@]}"; do
    if [[ "$branch" == *"${p}"* ]]; then
      echo "$p"
      return
    fi
  done

  echo ""
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_status() {
  echo "=== Lab Sync Status ==="
  echo ""

  load_branches

  # Show current heartbeat info from sessions.json on main
  local hb_log_date
  hb_log_date=$(date -u +%Y-%m-%d)
  local hb_url="${RAW_URL}/main/lab/heartbeats/${hb_log_date}.md"
  local hb_count
  hb_count=$(curl -sf "$hb_url" 2>/dev/null | grep -c "^## Heartbeat #" || echo 0)
  echo "  Heartbeat round: #${hb_count}"
  if [ "$hb_count" -gt 0 ]; then
    echo "  Full log: ${hb_url}"
  fi
  echo ""

  fetch_refs

  local current_persona
  current_persona=$(detect_persona)

  for persona in "${PERSONAS[@]}"; do
    local branch
    branch=$(branch_for "$persona")
    if [ -z "$branch" ]; then
      echo "  ${persona}: no active session"
      continue
    fi

    if ref_exists "$branch"; then
      local ahead last_commit
      ahead=$(git rev-list --count "lab/main..lab/${branch}" 2>/dev/null || echo "?")
      last_commit=$(git log -1 --format="%h %s" "lab/${branch}" 2>/dev/null || echo "unknown")
      local marker=""
      if [ "$persona" = "$current_persona" ]; then
        marker=" (you)"
      fi
      echo "  ${persona}${marker}: +${ahead} commits  ${last_commit}"
      echo "    browse: tools/lab-sync browse ${persona}"
    else
      echo "  ${persona}: branch ${branch} (not fetched)"
    fi
  done
}

cmd_diff() {
  local persona="${1:?Usage: lab-sync diff <persona>}"

  load_branches
  local branch
  branch=$(branch_for "$persona")
  if [ -z "$branch" ]; then
    echo "No active branch found for ${persona}."
    exit 1
  fi

  fetch_refs

  if ! ref_exists "$branch"; then
    echo "Branch ${branch} not fetched for ${persona}."
    exit 1
  fi

  echo "=== Diff: ${persona} (${branch}) vs main ==="
  echo ""
  git diff "lab/main..lab/${branch}" -- . ':!.jules' 2>/dev/null || {
    echo "No diff available (branches may be identical)."
  }
}

cmd_browse() {
  local persona="${1:?Usage: lab-sync browse <persona>}"

  load_branches
  local branch
  branch=$(branch_for "$persona")
  if [ -z "$branch" ]; then
    echo "No active branch found for ${persona}."
    exit 1
  fi

  fetch_refs

  if ! ref_exists "$branch"; then
    echo "Branch ${branch} not fetched for ${persona}."
    exit 1
  fi

  echo "=== Files changed by ${persona} (${branch}) ==="
  echo ""

  local files
  files=$(git diff --name-only "lab/main..lab/${branch}" -- . ':!.jules' 2>/dev/null || true)

  if [ -z "$files" ]; then
    echo "  (no changes vs main)"
    exit 0
  fi

  while IFS= read -r f; do
    echo "  ${f}"
    echo "    $(raw_url_for "$persona" "$f")"
  done <<< "$files"

  echo ""
  echo "To read a file: tools/lab-sync read ${persona} <filepath>"
  echo "Files fetched via 'read' are local-only (auto-added to .gitignore)."
}

cmd_read() {
  local persona="${1:?Usage: lab-sync read <persona> <filepath>}"
  local filepath="${2:?Usage: lab-sync read <persona> <filepath>}"

  load_branches
  local branch
  branch=$(branch_for "$persona")
  if [ -z "$branch" ]; then
    echo "No active branch found for ${persona}."
    exit 1
  fi

  local url
  url=$(raw_url_for "$persona" "$filepath")

  echo "Fetching: ${url}"

  # Create parent directory if needed
  local dir
  dir=$(dirname "$filepath")
  if [ "$dir" != "." ]; then
    mkdir -p "$dir"
  fi

  # Fetch the file
  if curl -sfL "$url" -o "$filepath"; then
    echo "Saved to: ${filepath}"
    # Add to .gitignore so it's never committed
    gitignore_add "$filepath"
    echo "Added to .gitignore (read-only, will not be committed)"
    echo ""
    echo "--- Content ---"
    cat "$filepath"
  else
    echo "ERROR: Could not fetch ${url}"
    echo "The file may not exist on ${persona}'s branch yet."
    exit 1
  fi
}

cmd_annotate() {
  local paper="${1:?Usage: lab-sync annotate <paper.tex>  (e.g. baldo_the_single_generative_act.tex)}"

  load_branches
  local me
  me=$(detect_persona)
  if [ -z "$me" ]; then
    echo "ERROR: Cannot detect your persona from branch name."
    exit 1
  fi

  # Extract author from paper filename (e.g. baldo_paper.tex -> baldo)
  local author=""
  for p in "${PERSONAS[@]}"; do
    if [[ "$paper" == "${p}_"* ]]; then
      author="$p"
      break
    fi
  done
  if [ -z "$author" ]; then
    echo "ERROR: Cannot determine author from filename '${paper}'."
    echo "Paper filenames must start with a persona prefix (e.g. baldo_paper.tex)."
    exit 1
  fi
  if [ "$author" = "$me" ]; then
    echo "ERROR: You own this paper — edit it directly, no patch needed."
    exit 1
  fi

  # The local copy should already exist (fetched via lab-sync read)
  local local_file="lab/${paper}"
  if [ ! -f "$local_file" ]; then
    echo "ERROR: ${local_file} not found locally."
    echo "First fetch it:  tools/lab-sync read ${author} lab/${paper}"
    echo "Then edit it and add your todonotes."
    echo "Then run:  tools/lab-sync annotate ${paper}"
    exit 1
  fi

  # Copy annotated version to patches dir, commit, and mail the author
  local patches_dir="lab/notes/${me}/patches"
  mkdir -p "$patches_dir"
  local patch_file="${patches_dir}/${paper}"

  cp "$local_file" "$patch_file"

  git add "$patch_file"
  git commit -m "${me}: annotate ${paper}"

  echo ""
  echo "Saved annotation to: ${patch_file}"
  echo "Committed."

  # Send mail to author
  python3 tools/lab-mail send "$author" -s "annotations on ${paper}" -b "I added todonotes to your paper via patch. Run: tools/lab-sync apply-patches"

  echo ""
  echo "Done! ${author} will see your annotations next session."
}

cmd_apply_patches() {
  load_branches
  local me
  me=$(detect_persona)
  if [ -z "$me" ]; then
    echo "ERROR: Cannot detect your persona from branch name."
    exit 1
  fi

  echo "=== Applying patches for ${me} ==="
  echo ""

  fetch_refs
  local found=0

  for annotator in "${PERSONAS[@]}"; do
    [ "$annotator" = "$me" ] && continue

    local branch
    branch=$(branch_for "$annotator")
    [ -z "$branch" ] && continue
    ! ref_exists "$branch" && continue

    # List files in annotator's patches dir that match our papers
    local patches_path="lab/notes/${annotator}/patches"
    local files
    files=$(git ls-tree --name-only "lab/${branch}" "${patches_path}/" 2>/dev/null || true)
    [ -z "$files" ] && continue

    while IFS= read -r filepath; do
      local filename
      filename=$(basename "$filepath")

      # Skip hidden files (originals)
      [[ "$filename" == .* ]] && continue

      # Only apply patches for papers we own
      if [[ "$filename" != "${me}_"* ]]; then
        continue
      fi

      echo "  Found annotation from ${annotator}: ${filename}"

      # Fetch the annotated version
      local annotated_url="${RAW_URL}/${branch}/${filepath}"
      local tmp_annotated="/tmp/lab_patch_${filename}"
      if ! curl -sfL "$annotated_url" -o "$tmp_annotated" 2>/dev/null; then
        echo "    ERROR: could not fetch annotated file"
        continue
      fi

      local my_paper="lab/${filename}"
      if [ ! -f "$my_paper" ]; then
        echo "    WARNING: ${my_paper} not found locally, skipping"
        rm -f "$tmp_annotated"
        continue
      fi

      # Show the diff
      echo "    Changes:"
      diff -u "$my_paper" "$tmp_annotated" || true
      echo ""

      # Apply: copy the annotated version over our paper
      cp "$tmp_annotated" "$my_paper"
      rm -f "$tmp_annotated"
      echo "    Applied to ${my_paper}"
      found=$((found + 1))

    done <<< "$files"
  done

  if [ "$found" -eq 0 ]; then
    echo "  (no pending patches found)"
  else
    echo ""
    echo "  ${found} patch(es) applied. Review the todonotes, then commit."
  fi
}

cmd_mail() {
  # Show inbox — mail is delivered centrally by the heartbeat workflow
  python3 tools/lab-mail list
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  status)        cmd_status ;;
  diff)          cmd_diff "${2:-}" ;;
  browse)        cmd_browse "${2:-}" ;;
  read)          cmd_read "${2:-}" "${3:-}" ;;
  annotate)      cmd_annotate "${2:-}" ;;
  apply-patches) cmd_apply_patches ;;
  mail)          cmd_mail ;;
  *)
    echo "Usage: tools/lab-sync {status|diff|browse|read|annotate|apply-patches|mail} [args]"
    echo ""
    echo "  status              List persona branches and latest commits"
    echo "  diff <persona>      Show what <persona> changed vs main"
    echo "  browse <persona>    List files changed by <persona> with raw GitHub URLs"
    echo "  read <persona> <f>  Fetch a file read-only (auto-added to .gitignore)"
    echo "  annotate <paper>    Fetch a paper for annotation (patch-based todonotes)"
    echo "  apply-patches       Apply pending annotations from other personas"
    echo "  mail                List your inbox (mail delivered by heartbeat)"
    echo ""
    echo "Annotate: tools/lab-sync annotate baldo_paper.tex"
    echo "          (edit, commit, then mail the author)"
    echo "Apply:    tools/lab-sync apply-patches"
    echo "          (finds and applies todonotes from other personas)"
    echo ""
    echo "Mail: tools/lab-mail send <recipient> -s 'subject' -b 'body'"
    echo "      tools/lab-mail list    — check your inbox"
    exit 1
    ;;
esac
