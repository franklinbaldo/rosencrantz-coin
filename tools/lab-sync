#!/usr/bin/env bash
# lab-sync — Cross-persona sync tool for Rosencrantz Lab.
#
# Usage inside a Jules session:
#   tools/lab-sync status              List today's persona branches + raw URLs
#   tools/lab-sync diff <persona>      Show what <persona> changed vs main
#   tools/lab-sync read <persona> <f>  Fetch a file from <persona>'s branch (read-only)
#   tools/lab-sync browse <persona>    List files changed by <persona> with raw URLs
#   tools/lab-sync mail                Fetch incoming mail from other personas' outboxes
#
# Files fetched via 'read' are saved locally but added to .gitignore
# so they are never committed to your branch.
# Mail delivered via 'mail' IS committed — it becomes part of your inbox history.
set -euo pipefail

REPO="franklinbaldo/rosencrantz-coin"
REPO_URL="https://github.com/${REPO}.git"
RAW_URL="https://raw.githubusercontent.com/${REPO}"
PERSONAS=(baldo scott sabine pearl fuchs liang wolfram mycroft giles)
DATE_PREFIX=$(date -u +%Y-%m-%d)

# ── Helpers ──────────────────────────────────────────────────────────────────

fetch_refs() {
  git fetch "$REPO_URL" '+refs/heads/*:refs/remotes/lab/*' --quiet 2>/dev/null || true
}

branch_for() {
  echo "${DATE_PREFIX}_${1}"
}

ref_exists() {
  git rev-parse --verify "lab/$1" >/dev/null 2>&1
}

raw_url_for() {
  local persona="$1" filepath="$2"
  echo "${RAW_URL}/$(branch_for "$persona")/${filepath}"
}

# Ensure a path is in .gitignore (idempotent)
gitignore_add() {
  local path="$1"
  local marker="# lab-sync read-only"
  if [ ! -f .gitignore ]; then
    echo "$marker" > .gitignore
    echo "$path" >> .gitignore
    return
  fi
  if ! grep -qxF "$path" .gitignore 2>/dev/null; then
    # Add marker section if not present
    if ! grep -qF "$marker" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "$marker" >> .gitignore
    fi
    echo "$path" >> .gitignore
  fi
}

# Detect current persona from branch name
detect_persona() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  for p in "${PERSONAS[@]}"; do
    if [[ "$branch" == *"_${p}" ]]; then
      echo "$p"
      return
    fi
  done
  echo ""
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_status() {
  echo "=== Lab Sync Status — ${DATE_PREFIX} ==="
  echo ""

  # Show current heartbeat number from log on main
  local hb_log="lab/heartbeats/${DATE_PREFIX}.md"
  local hb_url="${RAW_URL}/main/${hb_log}"
  local hb_count
  hb_count=$(curl -sf "$hb_url" 2>/dev/null | grep -c "^## Heartbeat #" || echo 0)
  echo "  Heartbeat round: #${hb_count}"
  if [ "$hb_count" -gt 0 ]; then
    echo "  Full log: ${hb_url}"
  fi
  echo ""

  fetch_refs

  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
  local current_persona=""
  for p in "${PERSONAS[@]}"; do
    if [[ "$current_branch" == *"_${p}" ]]; then
      current_persona="$p"
      break
    fi
  done

  for persona in "${PERSONAS[@]}"; do
    local branch
    branch=$(branch_for "$persona")
    if ref_exists "$branch"; then
      local ahead last_commit
      ahead=$(git rev-list --count "lab/main..lab/${branch}" 2>/dev/null || echo "?")
      last_commit=$(git log -1 --format="%h %s" "lab/${branch}" 2>/dev/null || echo "unknown")
      local marker=""
      if [ "$persona" = "$current_persona" ]; then
        marker=" (you)"
      fi
      echo "  ${persona}${marker}: +${ahead} commits  ${last_commit}"
      echo "    browse: tools/lab-sync browse ${persona}"
    else
      echo "  ${persona}: no branch today"
    fi
  done
}

cmd_diff() {
  local persona="${1:?Usage: lab-sync diff <persona>}"
  local branch
  branch=$(branch_for "$persona")

  fetch_refs

  if ! ref_exists "$branch"; then
    echo "No branch ${branch} found for ${persona} today."
    exit 1
  fi

  echo "=== Diff: ${persona} (${branch}) vs main ==="
  echo ""
  git diff "lab/main..lab/${branch}" -- . ':!.jules' 2>/dev/null || {
    echo "No diff available (branches may be identical)."
  }
}

cmd_browse() {
  local persona="${1:?Usage: lab-sync browse <persona>}"
  local branch
  branch=$(branch_for "$persona")

  fetch_refs

  if ! ref_exists "$branch"; then
    echo "No branch ${branch} found for ${persona} today."
    exit 1
  fi

  echo "=== Files changed by ${persona} (${branch}) ==="
  echo ""

  local files
  files=$(git diff --name-only "lab/main..lab/${branch}" -- . ':!.jules' 2>/dev/null || true)

  if [ -z "$files" ]; then
    echo "  (no changes vs main)"
    exit 0
  fi

  while IFS= read -r f; do
    echo "  ${f}"
    echo "    $(raw_url_for "$persona" "$f")"
  done <<< "$files"

  echo ""
  echo "To read a file: tools/lab-sync read ${persona} <filepath>"
  echo "Files fetched via 'read' are local-only (auto-added to .gitignore)."
}

cmd_read() {
  local persona="${1:?Usage: lab-sync read <persona> <filepath>}"
  local filepath="${2:?Usage: lab-sync read <persona> <filepath>}"
  local branch
  branch=$(branch_for "$persona")
  local url
  url=$(raw_url_for "$persona" "$filepath")

  echo "Fetching: ${url}"

  # Create parent directory if needed
  local dir
  dir=$(dirname "$filepath")
  if [ "$dir" != "." ]; then
    mkdir -p "$dir"
  fi

  # Fetch the file
  if curl -sfL "$url" -o "$filepath"; then
    echo "Saved to: ${filepath}"
    # Add to .gitignore so it's never committed
    gitignore_add "$filepath"
    echo "Added to .gitignore (read-only, will not be committed)"
    echo ""
    echo "--- Content ---"
    cat "$filepath"
  else
    echo "ERROR: Could not fetch ${url}"
    echo "The file may not exist on ${persona}'s branch yet."
    exit 1
  fi
}

cmd_mail() {
  local me
  me=$(detect_persona)
  if [ -z "$me" ]; then
    echo "ERROR: Cannot detect your persona from branch name."
    echo "Are you on a dated branch (e.g., 2026-03-05_baldo)?"
    exit 1
  fi

  echo "=== Mail for ${me} ==="
  echo ""

  fetch_refs

  local inbox_dir="lab/mail/${me}/inbox"
  mkdir -p "$inbox_dir"

  local delivered=0

  for sender in "${PERSONAS[@]}"; do
    [ "$sender" = "$me" ] && continue

    local branch
    branch=$(branch_for "$sender")
    if ! ref_exists "$branch"; then
      continue
    fi

    # List files in sender's outbox addressed to me
    local outbox_path="lab/mail/${sender}/outbox"
    local files
    files=$(git ls-tree --name-only "lab/${branch}" "${outbox_path}/" 2>/dev/null || true)

    if [ -z "$files" ]; then
      continue
    fi

    while IFS= read -r filepath; do
      local filename
      filename=$(basename "$filepath")

      # Only deliver mail addressed to me: to_{me}_*.md
      if [[ "$filename" != to_${me}_* ]]; then
        continue
      fi

      # Rename: to_me_date.md → from_sender_date.md
      local delivered_name="from_${sender}_${filename#to_${me}_}"
      local dest="${inbox_dir}/${delivered_name}"

      # Skip if already delivered
      if [ -f "$dest" ]; then
        continue
      fi

      local url
      url=$(raw_url_for "$sender" "$filepath")

      if curl -sfL "$url" -o "$dest"; then
        echo "  New mail from ${sender}: ${delivered_name}"
        delivered=$((delivered + 1))
      fi
    done <<< "$files"
  done

  if [ "$delivered" -eq 0 ]; then
    echo "  (no new mail)"
  else
    echo ""
    echo "  ${delivered} message(s) delivered to ${inbox_dir}/"
  fi

  # Also show any outgoing mail from me
  local outbox="lab/mail/${me}/outbox"
  if [ -d "$outbox" ]; then
    local outcount
    outcount=$(find "$outbox" -name "to_*.md" 2>/dev/null | wc -l)
    if [ "$outcount" -gt 0 ]; then
      echo ""
      echo "  Your outbox (${outcount} sent):"
      find "$outbox" -name "to_*.md" -exec basename {} \; | while read -r f; do
        echo "    ${f}"
      done
    fi
  fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  status)  cmd_status ;;
  diff)    cmd_diff "${2:-}" ;;
  browse)  cmd_browse "${2:-}" ;;
  read)    cmd_read "${2:-}" "${3:-}" ;;
  mail)    cmd_mail ;;
  *)
    echo "Usage: tools/lab-sync {status|diff|browse|read|mail} [args]"
    echo ""
    echo "  status              List today's persona branches and latest commits"
    echo "  diff <persona>      Show what <persona> changed vs main"
    echo "  browse <persona>    List files changed by <persona> with raw GitHub URLs"
    echo "  read <persona> <f>  Fetch a file read-only (auto-added to .gitignore)"
    echo "  mail                Fetch incoming mail from other personas' outboxes"
    echo ""
    echo "Mail: write to lab/mail/<you>/outbox/to_<recipient>_<date>.md"
    echo "      run 'lab-sync mail' to check your inbox"
    echo ""
    echo "All reads are non-destructive. Fetched files are gitignored to prevent"
    echo "accidentally committing other personas' work to your branch."
    exit 1
    ;;
esac
